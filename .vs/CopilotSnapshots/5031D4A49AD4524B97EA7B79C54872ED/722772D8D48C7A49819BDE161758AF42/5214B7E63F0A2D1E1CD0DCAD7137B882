using System;
using System.Drawing;
using System.Drawing.Drawing2D;

namespace ReproductorMúsica
{
    // Renderizador de la visualización de tipo "Polígonos" mejorada
    // Ahora dibuja varias formaciones de polígonos a distintas profundidades
    // que se escalan y desvanecen simulando que avanzan hacia el espectador.
    // Cada polígono reacciona a bandas del espectro y al pulso del ritmo.
    internal class PolygonVisualization
    {
        private class PolyInstance
        {
            public float XNorm; // 0..1 posición horizontal inicial
            public float YNorm; // 0..1 posición vertical inicial
            public float Z;     // 0..1 profundidad (1 = cerca)
            public float Speed; // avance por frame (aprox)
            public int Sides;
            public float BaseRadius; // fracción relativa al canvas min(width,height)
            public float HueOffset;
            public int BandIndex; // banda del espectro asociada
        }

        private List<PolyInstance> instances;
        private Random rand;
        private int targetCount = 36; // número de polígonos en pantalla

        public PolygonVisualization()
        {
            rand = new Random();
            InitializeInstances();
        }

        private void InitializeInstances()
        {
            instances = new List<PolyInstance>(targetCount);
            for (int i = 0; i < targetCount; i++)
            {
                instances.Add(CreateRandomInstance(initial:true));
            }
        }

        private PolyInstance CreateRandomInstance(bool initial = false)
        {
            var p = new PolyInstance();
            p.XNorm = (float)rand.NextDouble();
            p.YNorm = (float)rand.NextDouble();
            // Si es inicial repartir Z en todo el rango para evitar pop súbito
            p.Z = initial ? (float)rand.NextDouble() : 0f; // 0 = fondo, 1 = frente
            p.Speed = 0.006f + (float)rand.NextDouble() * 0.02f; // velocidad aleatoria
            p.Sides = 3 + rand.Next(0, 5); // 3..7 lados
            p.BaseRadius = 0.03f + (float)rand.NextDouble() * 0.08f; // fracción del min(canvas)
            p.HueOffset = (float)rand.NextDouble() * 360f;
            p.BandIndex = rand.Next(0, 16); // inicial, luego se mapeará según spectrum length
            return p;
        }

        // Dibuja y actualiza las instancias. Se llama cada frame desde CMediaPlayer.Timer_Tick.
        public void Draw(Graphics g, int offset, int linesToDraw, int cx, int cy, int radius, float[] spectrumSmooth, float beatPulse)
        {
            if (g == null || spectrumSmooth == null || spectrumSmooth.Length == 0) return;

            int width = cx * 2;
            int height = cy * 2;
            int minDim = Math.Min(width, height);

            // energía promedio para escalados globales
            float avg = 0f;
            for (int i = 0; i < spectrumSmooth.Length; i++) avg += spectrumSmooth[i];
            avg /= spectrumSmooth.Length;

            // actualizar y dibujar cada polígono
            for (int i = instances.Count - 1; i >= 0; i--)
            {
                var inst = instances[i];

                // avance dependiente de speed y del pulso para sincronizar con beats
                float speedMult = 1f + beatPulse * 2.6f;
                inst.Z += inst.Speed * speedMult;

                // si pasó al frente, reiniciar como uno nuevo en el fondo
                if (inst.Z > 1.0f)
                {
                    // reiniciar manteniendo la misma lista (evitar GC frecuente)
                    instances[i] = CreateRandomInstance(initial:false);
                    continue;
                }

                // Posición en pantalla: comenzamos dispersos y conforme Z aumenta se acercan al centro

                float spreadX = (inst.XNorm - 0.5f) * width * (1.0f - inst.Z * 0.65f);
                float spreadY = (inst.YNorm - 0.5f) * height * (1.0f - inst.Z * 0.65f);
                float px = cx + spreadX + (float)Math.Sin(offset * 0.01 + inst.HueOffset) * 6f * (1f - inst.Z);
                float py = cy + spreadY - inst.Z * (height * 0.18f); // subir ligeramente al acercarse

                // Tamaño relativo: aumenta con Z y con la energía promedio y beat pulse
                float size = inst.BaseRadius * minDim * (0.6f + inst.Z * 2.6f + avg * 0.9f + beatPulse * 12f);

                // Opacidad según Z: lejos más tenue, cerca más opaco
                int alpha = ColorUtils.ClampAlpha((int)(40 + inst.Z * 215));

                // Color base para este polígono según hue offset y Z
                Color baseColor = ColorUtils.ColorFromHue((int)((inst.HueOffset + inst.Z * 80f + offset * 0.18f) % 360));

                // Deformación por banda: elegimos una banda cercana al bandIndex y modulamos por beat
                int band = Math.Min(spectrumSmooth.Length - 1, Math.Max(0, inst.BandIndex));
                float bandVal = spectrumSmooth[band];
                float deformStrength = 0.4f + bandVal * (0.8f + inst.Z * 1.6f) + beatPulse * 0.8f;

                // Construir polígono alrededor de (px, py)
                int sides = inst.Sides;
                PointF[] pts = new PointF[sides];
                for (int s = 0; s < sides; s++)
                {
                    double ang = (s * 2.0 * Math.PI / sides) + offset * 0.012 + inst.HueOffset * 0.01;
                    int bandForVertex = Math.Min(spectrumSmooth.Length - 1, Math.Abs((inst.BandIndex + s) % spectrumSmooth.Length));
                    float bv = spectrumSmooth[bandForVertex];
                    float deform = 1.0f + bv * deformStrength;
                    float rx = size * deform * (float)Math.Cos(ang);
                    float ry = size * deform * (float)Math.Sin(ang);
                    pts[s] = new PointF(px + rx, py + ry);
                }

                // Dibujar con relleno semitransparente y borde suave
                try
                {
                    using (GraphicsPath path = new GraphicsPath())
                    {
                        path.AddPolygon(pts);
                        RectangleF bounds = path.GetBounds();

                        Color fillA = Color.FromArgb(alpha, baseColor.R, baseColor.G, baseColor.B);
                        Color fillB = Color.FromArgb((int)(alpha * 0.25f), 0, 0, 0);

                        using (LinearGradientBrush lg = new LinearGradientBrush(bounds, fillA, fillB, (float)((offset + i) % 360)))
                        {
                            Blend b = new Blend(3);
                            b.Positions = new float[] { 0f, 0.6f, 1f };
                            b.Factors = new float[] { 0.0f, 0.8f, 1f };
                            lg.Blend = b;
                            g.FillPath(lg, path);
                        }

                        using (Pen pen = new Pen(Color.FromArgb(Math.Min(255, alpha + 30), 255, 255, 255), Math.Max(1f, 1.2f + inst.Z * 1.6f)))
                        {
                            g.DrawPath(pen, path);
                        }
                    }
                }
                catch { }
            }
        }
    }
}
